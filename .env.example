# 复制为 .env 并填入你的密钥
# 1) 通义千问 / DashScope (qwen + text-embedding-v4 共用一个 Key)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 2) Tavily 在线检索 Key (功能二：辅助决策助手)，在 https://app.tavily.com 申请
TAVILY_API_KEY=your_tavily_api_key_here

# 3) 访问口令 (可选)：部署到公网时设置，防止别人直接刷你的 API / 烧 quota。
#    本地留空 = 不启用登录校验。生产环境把 APP_PASSWORD 填进部署平台的环境变量，别写进代码库。
APP_USER=admin
APP_PASSWORD=

# 4) 永久存储 (可选)：都留空 = 用本地文件(默认)；填了 = 走云端持久化。
#    Neon Postgres：对话历史 / 向量(pgvector) / 档案 / 报告 / 会话 / 文档
DATABASE_URL=
#    Cloudflare R2 (S3 兼容)：存上传的原始文件
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 5) 可观测性 (可选): LangSmith 追踪多Agent全链路。Key 在 https://smith.langchain.com 申请。
#    拿到 Key 后把 LANGSMITH_TRACING 改成 true 才开启;留空=不追踪(不报错)。
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=meeting-insight-agent
# 注: 成本按 DashScope 国内端点(默认)真实价计算(见 src/utils/pricing.py)
